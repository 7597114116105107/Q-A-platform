DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-long-random-string"
PORT=4000

# Optional: invoice emails after payment (leave empty to skip)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="QA Platform <your-email@gmail.com>"

# Set true for local testing anytime (production: remove or set false)
PAYMENT_WINDOW_ALWAYS_OPEN=true

# Payments accepted only 10:00–11:00 AM IST when above is false
